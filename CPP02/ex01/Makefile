# **************************************************************************** #
#                                 COMPILER                                     #
# **************************************************************************** #
CC		= c++
CFLAGS	= -Wall -Wextra -Werror -std=c++98
NAME	= fixed


# **************************************************************************** #
#                               FILE STRUCTURE                                 #
# **************************************************************************** #
OBJ_DIR	= obj/
SRCS	= main.cpp Fixed.cpp
OBJS	= $(addprefix $(OBJ_DIR), $(SRCS:.cpp=.o))


# **************************************************************************** #
#                                   RULES                                      #
# **************************************************************************** #
.SILENT:

all: $(NAME)

$(OBJ_DIR):
	mkdir -p $(OBJ_DIR)

$(OBJ_DIR)%.o: %.cpp | $(OBJ_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(NAME): $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $(NAME)


# **************************************************************************** #
#                                 CLEANING                                     #
# **************************************************************************** #
clean:
	rm -f $(OBJS)

fclean: clean
	rm -f $(NAME)
	rm -rf $(OBJ_DIR)

re: fclean all

.PHONY: all clean fclean re
